param(
    [string]$UnlockSecret = "mvp-regtest-unlock",
    [switch]$OmitUnlockSecret,
    [string]$Port = "COM3",
    [int]$Baud = 115200,

    [string]$Network = "REGTEST",

    [string]$TxidLe = "c2bd530ed9d7e40ba47027e8ffee41aa5b62c0ba36e5c20003ca63309dad31c8",
    [uint32]$Vout = 1,
    [uint64]$InputSats = 100000,

    [string]$PrevScript = "76a914751e76e8199196d454941c45d1b3a323f1433bd688ac",

    [string]$PayScript = "76a914f2124d94cabdb95d49479627cbbe5d7be609f73888ac",
    [uint64]$PaySats = 60000,

    [string]$ChangeScript = "76a914751e76e8199196d454941c45d1b3a323f1433bd688ac",
    [uint64]$ChangeSats = 30000,

    [string]$RawTxOutFile = "",

    [switch]$DryRun
)

$ErrorActionPreference = "Stop"

function New-WalletCommandLines {
    param(
    [string]$UnlockSecret = "mvp-regtest-unlock",
    [switch]$OmitUnlockSecret,
        [string]$Network,
        [string]$TxidLe,
        [uint32]$Vout,
        [uint64]$InputSats,
        [string]$PrevScript,
        [string]$PayScript,
        [uint64]$PaySats,
        [string]$ChangeScript,
        [uint64]$ChangeSats
    )

    return @(
        "NETWORK=$Network",
        "TXID_LE=$TxidLe",
        "VOUT=$Vout",
        "INPUT_SATS=$InputSats",
        "PREV_SCRIPT=$PrevScript",
        "PAY_SCRIPT=$PayScript",
        "PAY_SATS=$PaySats",
        "CHANGE_SCRIPT=$ChangeScript",
        "CHANGE_SATS=$ChangeSats",
        "SIGN"
    )
}

function Read-SerialUntil {
    param(
    [string]$UnlockSecret = "mvp-regtest-unlock",
    [switch]$OmitUnlockSecret,
        [System.IO.Ports.SerialPort]$Serial,
        [string[]]$Patterns,
        [int]$TimeoutSeconds = 30,
        [switch]$PrintChunks
    )

    $out = ""
    $deadline = (Get-Date).AddSeconds($TimeoutSeconds)

    while ((Get-Date) -lt $deadline) {
        Start-Sleep -Milliseconds 250

        $chunk = $Serial.ReadExisting()

        if ($chunk.Length -gt 0) {
            $out += $chunk

            if ($PrintChunks) {
                Write-Host $chunk
            }
        }

        foreach ($pattern in $Patterns) {
            if ($out -match $pattern) {
                return $out
            }
        }
    }

    return $out
}

function Open-WalletSerial {
    param(
    [string]$UnlockSecret = "mvp-regtest-unlock",
    [switch]$OmitUnlockSecret,
        [string]$Port,
        [int]$Baud
    )

    $serial = New-Object System.IO.Ports.SerialPort $Port, $Baud, None, 8, One
    $serial.ReadTimeout = 5000
    $serial.WriteTimeout = 5000
    $serial.DtrEnable = $true
    $serial.RtsEnable = $true
    $serial.Open()

    return $serial
}

$lines = New-WalletCommandLines `
    -Network $Network `
    -TxidLe $TxidLe `
    -Vout $Vout `
    -InputSats $InputSats `
    -PrevScript $PrevScript `
    -PayScript $PayScript `
    -PaySats $PaySats `
    -ChangeScript $ChangeScript `
    -ChangeSats $ChangeSats

$fee = [int64]$InputSats - [int64]$PaySats - [int64]$ChangeSats

Write-Host ""
Write-Host "--- GENERATED WALLET COMMAND ---"

foreach ($line in $lines) {
    Write-Host $line
}

Write-Host ""
Write-Host "--- LOCAL AMOUNT SUMMARY ---"
Write-Host "INPUT_SATS=$InputSats"
Write-Host "PAY_SATS=$PaySats"
Write-Host "CHANGE_SATS=$ChangeSats"
Write-Host "FEE_SATS=$fee"

if ($DryRun) {
    Write-Host ""
    Write-Host "DRY_RUN_ONLY"
    exit 0
}

$sp = $null

try {
    Write-Host ""
    Write-Host "--- OPEN SERIAL $Port ---"

    $sp = Open-WalletSerial -Port $Port -Baud $Baud

    Start-Sleep -Seconds 3

    $startup = $sp.ReadExisting()

    if ($startup.Length -gt 0) {
        Write-Host $startup
    }

    if ($startup -notmatch "READY" -and $startup -notmatch ">") {
        Write-Host ""
        Write-Host "--- WAITING FOR READY ---"

        $startup += Read-SerialUntil `
            -Serial $sp `
            -Patterns @("READY", ">") `
            -TimeoutSeconds 15 `
            -PrintChunks
    }

    Write-Host ""
    Write-Host "--- SEND SIGN COMMAND ---"

    foreach ($line in $lines) {
        $sp.Write($line + "`r`n")
        Start-Sleep -Milliseconds 100
    }

    Write-Host ""
    Write-Host "--- WALLET RESPONSE ---"

    $response = Read-SerialUntil `
        -Serial $sp `
        -Patterns @("RAW_TX=", "ERR ") `
        -TimeoutSeconds 45 `
        -PrintChunks

    Start-Sleep -Seconds 1
    $response += $sp.ReadExisting()

    $rawMatch = [regex]::Match($response, "RAW_TX=([0-9a-fA-F]+)")

    if ($rawMatch.Success) {
        $rawTx = $rawMatch.Groups[1].Value

        Write-Host ""
        Write-Host "--- RAW TX EXTRACTED ---"
        Write-Host $rawTx

        if ($RawTxOutFile -ne "") {
            Set-Content -Path $RawTxOutFile -Value $rawTx -Encoding ascii
            Write-Host ""
            Write-Host "RAW_TX_WRITTEN_TO=$RawTxOutFile"
        }

        Write-Host ""
        Write-Host "HOST_TX_GENERATOR_PASS"
        exit 0
    }

    $errMatch = [regex]::Match($response, "ERR [A-Z_]+ -?\d+")

    if ($errMatch.Success) {
        Write-Host ""
        Write-Host "--- WALLET ERROR ---"
        Write-Host $errMatch.Value
        Write-Host ""
        Write-Host "HOST_TX_GENERATOR_FAIL"
        exit 1
    }

    Write-Host ""
    Write-Host "--- NO RAW_TX OR ERR FOUND ---"
    Write-Host $response
    Write-Host ""
    Write-Host "HOST_TX_GENERATOR_FAIL"
    exit 1
}
finally {
    if ($sp -ne $null) {
        if ($sp.IsOpen) {
            $sp.Close()
        }

        $sp.Dispose()
    }
}

