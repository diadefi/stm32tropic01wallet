static int wallet_uart_command_is_exact(const char *cmd,
                                        const char *expected)
{
    size_t expected_len;

    if (cmd == NULL || expected == NULL)
    {
        return 0;
    }

    while (*cmd == '\r' || *cmd == '\n' || *cmd == ' ' || *cmd == '\t')
    {
        cmd++;
    }

    expected_len = strlen(expected);

    if (strncmp(cmd, expected, expected_len) != 0)
    {
        return 0;
    }

    cmd += expected_len;

    while (*cmd == '\r' || *cmd == '\n' || *cmd == ' ' || *cmd == '\t')
    {
        cmd++;
    }

    return (*cmd == '\0');
}

