static void wallet_uart_send_str(const char *s)
{
    if (s == NULL)
    {
        return;
    }

    uint32_t len = (uint32_t)strlen(s);
    wallet_uart_tx_len = len;

    (void)HAL_UART_Transmit(
        &hcom_uart[COM1],
        (uint8_t *)s,
        len,
        HAL_MAX_DELAY
    );
}

