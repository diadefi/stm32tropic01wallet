#define WALLET_BLOB_SECRET_KEY      "UNLOCK_SECRET"
#define WALLET_BLOB_UNLOCK_MISSING  -22
#define WALLET_BLOB_UNLOCK_BAD      -23

/*
 * MVP encrypted key blob.
 *
 * The long-term secp256k1 test key is not stored directly as a plaintext
 * byte array or plaintext hex literal in firmware anymore.
 *
 * MVP unwrap:
 * mask = SHA256("WALLET_BLOB_V1_MASK" || salt || unlock_secret)
 * key  = ciphertext XOR mask
 * tag  = SHA256("WALLET_BLOB_V1_TAG" || salt || ciphertext || unlock_secret)
 *
 * This is an MVP architecture proof, not production AEAD.
 */
static const uint8_t WALLET_KEY_BLOB_SALT[16] =
{
    0xf1, 0xe2, 0xd3, 0xc4,
    0xb5, 0xa6, 0x97, 0x88,
    0x77, 0x66, 0x55, 0x44,
    0x33, 0x22, 0x11, 0x00
};

static const uint8_t WALLET_KEY_BLOB_CIPHERTEXT[32] =
{
    0x99, 0x41, 0xd1, 0xb6,
    0xb7, 0xa8, 0x07, 0xf7,
    0x21, 0xee, 0xc5, 0x37,
    0xe2, 0x74, 0x5c, 0x43,
    0x78, 0x35, 0xef, 0x4e,
    0x8c, 0x6a, 0x2a, 0x9c,
    0x9b, 0x78, 0x2e, 0x15,
    0x56, 0x94, 0xca, 0x77
};

static const uint8_t WALLET_KEY_BLOB_TAG[32] =
{
    0x24, 0xf1, 0x02, 0x6b,
    0x2f, 0x59, 0x8c, 0x68,
    0x6a, 0xb8, 0x16, 0x6d,
    0xc2, 0x17, 0x8a, 0x26,
    0x61, 0xa6, 0xc4, 0xb5,
    0x60, 0xa3, 0x3d, 0xa8,
    0x41, 0x01, 0xdf, 0x1c,
    0x9b, 0x40, 0x90, 0xac
};

static void wallet_key_provider_secure_zero(uint8_t *buf, size_t len)
{
    volatile uint8_t *p = (volatile uint8_t *)buf;

    if (p == NULL)
    {
        return;
    }

    while (len > 0U)
    {
        *p = 0U;
        p++;
        len--;
    }
}

static int wallet_key_provider_find_value(const char *text,
                                          const char *key,
                                          const char **value_start,
                                          size_t *value_len)
{
    const char *p;
    const char *v;
    const char *e;
    size_t key_len;

    if (text == NULL || key == NULL || value_start == NULL || value_len == NULL)
    {
        return 0;
    }

    key_len = strlen(key);
    p = strstr(text, key);

    if (p == NULL)
    {
        return 0;
    }

    v = p + key_len;

    if (*v != '=')
    {
        return 0;
    }

    v++;

    e = v;

    while (*e != '\0' && *e != '\r' && *e != '\n')
    {
        e++;
    }

    if (e == v)
    {
        return 0;
    }

    *value_start = v;
    *value_len = (size_t)(e - v);

    return 1;
}

static int wallet_key_provider_sha256(const uint8_t *a, size_t a_len,
                                      const uint8_t *b, size_t b_len,
                                      const uint8_t *c, size_t c_len,
                                      const uint8_t *d, size_t d_len,
                                      uint8_t out[32])
{
    psa_hash_operation_t op = PSA_HASH_OPERATION_INIT;
    psa_status_t status;
    size_t hash_len = 0U;

    status = psa_hash_setup(&op, PSA_ALG_SHA_256);
    if (status != PSA_SUCCESS)
    {
        return -1;
    }

    if (a != NULL && a_len > 0U)
    {
        status = psa_hash_update(&op, a, a_len);
        if (status != PSA_SUCCESS) { psa_hash_abort(&op); return -2; }
    }

    if (b != NULL && b_len > 0U)
    {
        status = psa_hash_update(&op, b, b_len);
        if (status != PSA_SUCCESS) { psa_hash_abort(&op); return -3; }
    }

    if (c != NULL && c_len > 0U)
    {
        status = psa_hash_update(&op, c, c_len);
        if (status != PSA_SUCCESS) { psa_hash_abort(&op); return -4; }
    }

    if (d != NULL && d_len > 0U)
    {
        status = psa_hash_update(&op, d, d_len);
        if (status != PSA_SUCCESS) { psa_hash_abort(&op); return -5; }
    }

    status = psa_hash_finish(&op, out, 32U, &hash_len);
    if (status != PSA_SUCCESS || hash_len != 32U)
    {
        psa_hash_abort(&op);
        return -6;
    }

    return 0;
}

static int wallet_key_provider_tag_equals(const uint8_t a[32],
                                          const uint8_t b[32])
{
    uint8_t diff = 0U;

    for (size_t i = 0; i < 32U; i++)
    {
        diff |= (uint8_t)(a[i] ^ b[i]);
    }

    return diff == 0U;
}

static int wallet_key_provider_unwrap_blob(const char *unlock_secret,
                                           size_t unlock_secret_len,
                                           uint8_t *out_key,
                                           size_t out_key_size)
{
    static const uint8_t mask_label[] = "WALLET_BLOB_V1_MASK";
    static const uint8_t tag_label[] = "WALLET_BLOB_V1_TAG";

    uint8_t mask[32];
    uint8_t tag[32];

    if (unlock_secret == NULL || unlock_secret_len == 0U)
    {
        return WALLET_BLOB_UNLOCK_MISSING;
    }

    if (out_key == NULL || out_key_size < WALLET_KEY_PROVIDER_PRIVKEY_BYTES_LEN)
    {
        return -2;
    }

    memset(mask, 0, sizeof(mask));
    memset(tag, 0, sizeof(tag));

    if (wallet_key_provider_sha256(mask_label,
                                   sizeof(mask_label) - 1U,
                                   WALLET_KEY_BLOB_SALT,
                                   sizeof(WALLET_KEY_BLOB_SALT),
                                   (const uint8_t *)unlock_secret,
                                   unlock_secret_len,
                                   NULL,
                                   0U,
                                   mask) != 0)
    {
        wallet_key_provider_secure_zero(mask, sizeof(mask));
        return -30;
    }

    if (wallet_key_provider_sha256(tag_label,
                                   sizeof(tag_label) - 1U,
                                   WALLET_KEY_BLOB_SALT,
                                   sizeof(WALLET_KEY_BLOB_SALT),
                                   WALLET_KEY_BLOB_CIPHERTEXT,
                                   sizeof(WALLET_KEY_BLOB_CIPHERTEXT),
                                   (const uint8_t *)unlock_secret,
                                   unlock_secret_len,
                                   tag) != 0)
    {
        wallet_key_provider_secure_zero(mask, sizeof(mask));
        wallet_key_provider_secure_zero(tag, sizeof(tag));
        return -31;
    }

    if (!wallet_key_provider_tag_equals(tag, WALLET_KEY_BLOB_TAG))
    {
        wallet_key_provider_secure_zero(mask, sizeof(mask));
        wallet_key_provider_secure_zero(tag, sizeof(tag));
        memset(out_key, 0, out_key_size);
        return WALLET_BLOB_UNLOCK_BAD;
    }

    memset(out_key, 0, out_key_size);

    for (size_t i = 0; i < WALLET_KEY_PROVIDER_PRIVKEY_BYTES_LEN; i++)
    {
        out_key[i] = (uint8_t)(WALLET_KEY_BLOB_CIPHERTEXT[i] ^ mask[i]);
    }

    wallet_key_provider_secure_zero(mask, sizeof(mask));
    wallet_key_provider_secure_zero(tag, sizeof(tag));

    return 0;
}

int wallet_key_provider_get_private_key_bytes_for_command(const char *command_text,
                                                          uint8_t *out_key,
                                                          size_t out_key_size)
{
    const char *unlock_secret;
    size_t unlock_secret_len;
    int se_ret;
    int unwrap_ret;

    if (out_key == NULL)
    {
        return -1;
    }

    if (out_key_size < WALLET_KEY_PROVIDER_PRIVKEY_BYTES_LEN)
    {
        return -2;
    }

    memset(out_key, 0, out_key_size);

    if (!wallet_key_provider_find_value(command_text,
                                        WALLET_BLOB_SECRET_KEY,
                                        &unlock_secret,
                                        &unlock_secret_len))
    {
        return WALLET_BLOB_UNLOCK_MISSING;
    }

    /*
     * Secure-element authorization gate still happens before key unwrap.
     */
    se_ret = wallet_secure_element_authorize_key_use();

    if (se_ret != 0)
    {
        memset(out_key, 0, out_key_size);
        return -10;
    }

    unwrap_ret = wallet_key_provider_unwrap_blob(unlock_secret,
                                                unlock_secret_len,
                                                out_key,
                                                out_key_size);

    if (unwrap_ret != 0)
    {
        memset(out_key, 0, out_key_size);
        return unwrap_ret;
    }

    return 0;
}

/*
 * Legacy wrapper.
 *
 * Keep symbol for older code/tests, but do not allow key release without
 * command-provided unlock material.
 */
int wallet_key_provider_get_private_key_bytes(uint8_t *out_key,
                                               size_t out_key_size)
{
    if (out_key != NULL)
    {
        memset(out_key, 0, out_key_size);
    }

    return WALLET_BLOB_UNLOCK_MISSING;
}

int wallet_key_provider_get_private_key_hex(char *out_hex,
                                            size_t out_hex_size)
{
    if (out_hex != NULL && out_hex_size > 0U)
    {
        out_hex[0] = '\0';
    }

    return -99;
}

